# Copia este archivo a .env y NO lo subas al repo (.gitignore lo excluye).
# Para produccion: usa secret manager (Vault, AWS Secrets, etc.) — nunca este archivo.

# Postgres
POSTGRES_DB=billetera
POSTGRES_USER=billetera
POSTGRES_PASSWORD=cambia_esto_local_dev
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=billetera
RABBITMQ_PASSWORD=cambia_esto_local_dev
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# pgAdmin
PGADMIN_EMAIL=admin@billetera.local
PGADMIN_PASSWORD=cambia_esto_local_dev
PGADMIN_PORT=5050

# API
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# EF design-time (para correr `dotnet ef migrations add` contra el postgres local)
BILLETERA_DESIGN_CONN=Host=localhost;Port=5432;Database=billetera;Username=billetera;Password=cambia_esto_local_dev
