{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Billetera": "Host=postgres;Port=5432;Database=billetera;Username=billetera;Password=billetera"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "billetera",
    "Password": "billetera"
  },
  "Renaper": {
    "BaseUrl": "https://renaper.example.com",
    "TimeoutSeconds": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "MassTransit": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
